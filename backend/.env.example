# Backend API (see server.js)
PORT=4000
NODE_ENV=development
# CORS allow-list for the patient app. In production use the deployed https:// frontend origin.
FRONTEND_URL=http://localhost:3000

# PostgreSQL (optional). When set, audit events INSERT into audit_logs; run: npm run migrate
# DATABASE_URL=postgres://user:pass@localhost:5432/aegis
# PG_POOL_MAX=10

# Semver or build id surfaced in regulatoryContext.softwareVersion
APP_VERSION=0.1.0

# Audit: set to 1 to echo each audit row to stdout (in addition to in-memory store)
AUDIT_LOG_STDOUT=0

# Cap for in-memory audit ring buffer (mirrors audit_logs until DB writer exists)
AUDIT_MAX_IN_MEMORY_EVENTS=10000

# NHS integration scaffold (Phase 3). Keep disabled unless fully configured.
NHS_INTEGRATION_ENABLED=false
NHS_INTEGRATION_PROVIDER=nhs_stub
NHS_INTEGRATION_ENV=sandbox
NHS_AUTH_BASE_URL=https://auth.example.nhs.uk
NHS_CLIENT_ID=
NHS_REDIRECT_URI=http://localhost:3000/nhs/callback