{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "summary-get.response.json",
  "title": "GET /api/summary/:id success response",
  "type": "object",
  "required": ["id", "pathway", "pathwayLabel", "redFlagTriggered", "pharmacyEligible", "outcome", "outcomeLabel", "outcomeReason", "summaryText"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "createdAt": { "type": "string" },
    "patient": {
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "age": { "type": "integer" },
        "gender": { "type": "string" }
      },
      "additionalProperties": true
    },
    "pathway": { "type": "string" },
    "pathwayLabel": { "type": "string" },
    "symptoms": { "type": "array", "items": { "type": "string" } },
    "answers": { "type": "object", "additionalProperties": true },
    "redFlagTriggered": { "type": "boolean" },
    "redFlagReasons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": { "type": "string" },
          "description": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "pharmacyEligible": { "type": "boolean" },
    "outcome": { "type": "string" },
    "outcomeLabel": { "type": "string" },
    "outcomeReason": { "type": "string" },
    "explanation": {
      "type": "object",
      "properties": {
        "decision": { "type": "string" },
        "reason": { "type": "string" },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "decision": {
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "label": { "type": "string" },
        "urgency": { "type": "string" },
        "title": { "type": "string" }
      },
      "additionalProperties": true
    },
    "reasoning": {
      "type": "object",
      "properties": {
        "steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "clinicalBasis": {
          "type": "array",
          "items": { "type": "string" }
        },
        "engine": {
          "type": "object",
          "properties": {
            "source": { "type": "string" },
            "ruleIdsMatched": {
              "type": "array",
              "items": { "type": "string" }
            },
            "governanceUncertainty": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "referralRecommendation": {
      "type": "object",
      "properties": {
        "service": { "type": "string" },
        "instruction": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "escalationSafetyNet": {
          "type": "array",
          "items": { "type": "string" }
        },
        "contact": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "value": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "summaryText": { "type": "string" },
    "pathwayPatientDisclaimer": { "type": ["string", "null"] },
    "safetyNetAdvice": { "type": ["string", "null"] },
    "pharmacyTreatmentOptions": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "selfCareAdvice": { "type": ["string", "null"] },
    "status": { "type": "string" },
    "patientExplanation": { "type": "string" },
    "comorbidityModifiersApplied": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "blockPharmacy": { "type": "boolean" },
          "reason": { "type": "string" },
          "patientExplanationAppend": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "governanceUncertainty": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
