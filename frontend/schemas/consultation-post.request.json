{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "consultation-post.request.json",
  "title": "POST /api/consultation request body",
  "type": "object",
  "required": ["pathwayCode", "answers"],
  "additionalProperties": false,
  "properties": {
    "pathwayCode": {
      "type": "string",
      "description": "Clinical pathway code matching backend/data/pathways/<code>.json"
    },
    "answers": {
      "type": "object",
      "description": "Question id → value. Booleans, strings, string[] (e.g. impetigo q2 multiselect). Impetigo may include derived q2_areas_count.",
      "additionalProperties": true
    },
    "patient": {
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "age": { "type": "integer" },
        "gender": { "type": "string" }
      },
      "additionalProperties": true
    },
    "symptoms": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
