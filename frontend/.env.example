# Backend API (Express). Used when mocks are off or for CRM/admin fetches.
# Local dev uses HTTP; production must use https://… for the live API so traffic is encrypted in transit.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Consultation + summary (apiFetch): false = always hit real network; unset or any other value = use
# in-browser mocks first (and again if the network fails) so the patient flow works without a backend.
# NEXT_PUBLIC_USE_API_MOCKS=false